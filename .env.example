# Account Intelligence Radar - Environment Variables
# Copy this file to .env and fill in your API keys

# =============================================================
# REQUIRED: API Keys
# =============================================================

# SerpAPI - Google Search API for discovery layer
# Get yours at: https://serpapi.com/
SERPAPI_KEY=your_serpapi_key_here

# DeepSeek API - LLM for URL selection and reasoning
# Get yours at: https://platform.deepseek.com/
# Note: Handle HTTP 402 errors by topping up balance
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Firecrawl - Web extraction API
# Get yours at: https://firecrawl.dev/
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# =============================================================
# OPTIONAL: Override defaults
# =============================================================

# DeepSeek model (default: deepseek-reasoner)
# DEEPSEEK_MODEL=deepseek-reasoner

# Maximum URLs to extract per job (default: 5)
# MAX_URLS_PER_JOB=5

# Number of top companies for geography mode (default: 3)
# TOP_N_COMPANIES=3

# CORS origins (comma-separated, default: localhost dev ports)
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Reports output directory (default: reports)
# REPORTS_DIR=reports
